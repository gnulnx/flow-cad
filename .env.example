# Optional local tool paths. Copy to .env or .erb-cad.local.toml and adjust per machine.

# Defaults to ~/BLR/text-to-cad when unset.
TEXT_TO_CAD_ROOT=~/BLR/text-to-cad

# Defaults to $TEXT_TO_CAD_ROOT/.venv/bin/python when unset.
TEXT_TO_CAD_PYTHON=~/BLR/text-to-cad/.venv/bin/python

# Optional. Set this when FreeCAD exports are needed.
# Linux examples often look like /usr/bin/freecadcmd or /usr/bin/FreeCADCmd.
# macOS examples often look like /Applications/FreeCAD.app/Contents/Resources/bin/freecadcmd.
FREECAD_CMD=/path/to/freecadcmd
